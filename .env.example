# Opttwo Custom App 部署環境變數
# 複製成 .env 後填入實際值（.env 已 gitignore，絕不入庫）
#
# 用法：
#   set -a && source .env && set +a
#   python3 vfs/scripts/deploy_admin.py
#   python3 vfs/scripts/deploy_ordering.py

# AI GO 登入帳密（向平台方索取，需有 builder 權限）
AIGO_EMAIL=
AIGO_PASSWORD=

# 兩個 Custom App 的 UUID（向平台方索取）
ADMIN_APP_ID=
ORDERING_APP_ID=
